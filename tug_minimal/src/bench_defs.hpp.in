    .ncols = 200,
    .nrows = 200,
    .s_x = 1,
    .s_y = 1,
    .boundary = {.north_const = {0, 1, 2, 3, 4},
                 .south_const = {},
                 .east_const = {},
                 .west_const = {0, 1, 2, 3, 4},
                 .values = {111.0124, 55.50622, -3.336970273297e-08, 0.1, 0.2,
                            .0, .0}},
    .timestep = 1000,
